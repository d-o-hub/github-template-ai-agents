{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CLI Output Schema",
  "description": "Standard structure for CLI command outputs",
  "type": "object",
  "properties": {
    "command": {
      "type": "string"
    },
    "exit_code": {
      "type": "integer"
    },
    "stdout": {
      "type": "string"
    },
    "stderr": {
      "type": "string"
    }
  },
  "required": ["command", "exit_code"]
}
