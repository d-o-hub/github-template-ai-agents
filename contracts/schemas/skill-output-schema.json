{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Output Schema",
  "description": "Standard structure for agent skill output files",
  "type": "object",
  "properties": {
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure", "pending"]
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "required": ["version", "status"]
}
