#!/usr/bin/env bats
# BATS test for loc_gate.sh: Verify it excludes files inside nested node_modules folders

# Global setup
setup_file() {
    export REPO_ROOT="$(cd "$(dirname "$BATS_TEST_FILENAME")/.." && pwd)"
}

# Per-test setup
setup() {
    cd "$REPO_ROOT" || exit 1
}

@test "loc_gate.sh excludes files in nested node_modules folders" {
    # Create a temporary directory with nested node_modules
    TEMP_DIR=$(mktemp -d)
    mkdir -p "$TEMP_DIR/scripts"
    
    # Copy loc_gate.sh
    cp scripts/loc_gate.sh "$TEMP_DIR/scripts/"
    chmod +x "$TEMP_DIR/scripts/loc_gate.sh"
    
    # Create a structure with nested node_modules
    mkdir -p "$TEMP_DIR/src/module1/node_modules/deep-nested"
    mkdir -p "$TEMP_DIR/src/module2/node_modules"
    mkdir -p "$TEMP_DIR/node_modules/top-level"
    
    # Create files with many lines in nested node_modules
    # These should be excluded from LOC checking
    for i in $(seq 1 1000); do
        echo "line $i" >> "$TEMP_DIR/src/module1/node_modules/deep-nested/large-file.js"
    done
    
    for i in $(seq 1 1000); do
        echo "line $i" >> "$TEMP_DIR/src/module2/node_modules/another-large-file.ts"
    done
    
    # Create files in top-level node_modules
    for i in $(seq 1 1000); do
        echo "line $i" >> "$TEMP_DIR/node_modules/top-level/large-file.js"
    done
    
    # Create a normal source file that should be checked
    mkdir -p "$TEMP_DIR/src"
    echo "small file" > "$TEMP_DIR/src/normal-file.js"
    
    # Create AGENTS.md with LOC limits (high enough for loc_gate.sh itself)
    cat > "$TEMP_DIR/AGENTS.md" <<'EOF'
MAX_LINES_PER_SOURCE_FILE=500
EOF
    
    # Create .agents/skills dir to prevent find error
    mkdir -p "$TEMP_DIR/.agents/skills"
    
    cd "$TEMP_DIR" || exit 1
    
    # Run loc_gate.sh - should pass because:
    # 1. Files in nested node_modules are excluded
    # 2. Only normal-file.js with 1 line would be checked
    run ./scripts/loc_gate.sh
    
    # Should pass (exit 0)
    [ "$status" -eq 0 ]
    
    # Cleanup
    cd "$REPO_ROOT" || exit 1
    rm -rf "$TEMP_DIR"
}

@test "loc_gate.sh includes files NOT in node_modules folders" {
    # Create a temporary directory
    TEMP_DIR=$(mktemp -d)
    mkdir -p "$TEMP_DIR/scripts"
    
    # Copy loc_gate.sh
    cp scripts/loc_gate.sh "$TEMP_DIR/scripts/"
    chmod +x "$TEMP_DIR/scripts/loc_gate.sh"
    
    # Create a large file outside node_modules
    mkdir -p "$TEMP_DIR/src"
    for i in $(seq 1 1000); do
        echo "line $i" >> "$TEMP_DIR/src/large-file.js"
    done
    
    # Create AGENTS.md with low LOC limit
    cat > "$TEMP_DIR/AGENTS.md" <<'EOF'
MAX_LINES_PER_SOURCE_FILE=50
EOF
    
    # Create .agents/skills dir to prevent find error
    mkdir -p "$TEMP_DIR/.agents/skills"
    
    cd "$TEMP_DIR" || exit 1
    
    # Run loc_gate.sh - should fail because large-file.js has 1000 lines > 50
    run ./scripts/loc_gate.sh
    
    # Should fail (exit 1) because large-file.js exceeds limit
    [ "$status" -eq 1 ]
    
    # Output should mention the large file
    [[ "$output" == *"large-file.js"* ]] || [[ "$output" == *"LOC check failed"* ]]
    
    # Cleanup
    cd "$REPO_ROOT" || exit 1
    rm -rf "$TEMP_DIR"
}

@test "loc_gate.sh excludes deeply nested node_modules" {
    # Create a temporary directory with deeply nested node_modules
    TEMP_DIR=$(mktemp -d)
    mkdir -p "$TEMP_DIR/scripts"
    
    # Copy loc_gate.sh
    cp scripts/loc_gate.sh "$TEMP_DIR/scripts/"
    chmod +x "$TEMP_DIR/scripts/loc_gate.sh"
    
    # Create deeply nested structure: src/a/b/c/node_modules
    mkdir -p "$TEMP_DIR/src/a/b/c/node_modules/deep"
    
    # Create large file in deeply nested node_modules
    for i in $(seq 1 1000); do
        echo "line $i" >> "$TEMP_DIR/src/a/b/c/node_modules/deep/huge-file.js"
    done
    
    # Create small normal file
    echo "small" > "$TEMP_DIR/src/small.js"
    
    # Create AGENTS.md with LOC limits (high enough for loc_gate.sh itself)
    cat > "$TEMP_DIR/AGENTS.md" <<'EOF'
MAX_LINES_PER_SOURCE_FILE=500
EOF
    
    # Create .agents/skills dir to prevent find error
    mkdir -p "$TEMP_DIR/.agents/skills"
    
    cd "$TEMP_DIR" || exit 1
    
    # Run loc_gate.sh - should pass
    run ./scripts/loc_gate.sh
    
    # Should pass (exit 0) because:
    # - Files in deeply nested node_modules are excluded
    # - The only checked file (small.js) is small
    [ "$status" -eq 0 ]
    
    # Cleanup
    cd "$REPO_ROOT" || exit 1
    rm -rf "$TEMP_DIR"
}

@test "loc_gate.sh handles multiple nested node_modules directories" {
    # Create a temporary directory
    TEMP_DIR=$(mktemp -d)
    mkdir -p "$TEMP_DIR/scripts"
    
    # Copy loc_gate.sh
    cp scripts/loc_gate.sh "$TEMP_DIR/scripts/"
    chmod +x "$TEMP_DIR/scripts/loc_gate.sh"
    
    # Create multiple nested node_modules
    mkdir -p "$TEMP_DIR/src/mod1/node_modules/lib1"
    mkdir -p "$TEMP_DIR/src/mod2/node_modules/lib2"
    mkdir -p "$TEMP_DIR/src/mod3/node_modules/lib3/node_modules/deep"
    
    # Create large files in all nested node_modules
    for dir in "$TEMP_DIR/src/mod1/node_modules/lib1" \
               "$TEMP_DIR/src/mod2/node_modules/lib2" \
               "$TEMP_DIR/src/mod3/node_modules/lib3/node_modules/deep"; do
        for i in $(seq 1 1000); do
            echo "line $i" >> "$dir/large.js"
        done
    done
    
    # Create small normal files
    echo "small1" > "$TEMP_DIR/src/mod1/file.js"
    echo "small2" > "$TEMP_DIR/src/mod2/file.js"
    
    # Create AGENTS.md with LOC limit (high enough for loc_gate.sh itself)
    cat > "$TEMP_DIR/AGENTS.md" <<'EOF'
MAX_LINES_PER_SOURCE_FILE=500
EOF
    
    # Create .agents/skills dir to prevent find error
    mkdir -p "$TEMP_DIR/.agents/skills"
    
    cd "$TEMP_DIR" || exit 1
    
    # Run loc_gate.sh - should pass
    run ./scripts/loc_gate.sh
    
    # Should pass (exit 0)
    [ "$status" -eq 0 ]
    
    # Cleanup
    cd "$REPO_ROOT" || exit 1
    rm -rf "$TEMP_DIR"
}
